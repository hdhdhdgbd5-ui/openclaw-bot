# CryptoTradeGenius - Environment Configuration

# Trading Mode
TRADING_MODE=paper  # paper or live
LOG_LEVEL=INFO

# Exchange API Keys (Paper Trading)
BINANCE_TESTNET_API_KEY=your_binance_testnet_key
BINANCE_TESTNET_SECRET=your_binance_testnet_secret
COINBASE_SANDBOX_API_KEY=your_coinbase_sandbox_key
COINBASE_SANDBOX_SECRET=your_coinbase_sandbox_secret

# Exchange API Keys (Live Trading - USE WITH CAUTION!)
BINANCE_API_KEY=your_binance_api_key
BINANCE_SECRET=your_binance_secret
COINBASE_API_KEY=your_coinbase_api_key
COINBASE_SECRET=your_coinbase_secret

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id
TELEGRAM_ADMIN_IDS=admin1_id,admin2_id

# Database
DATABASE_URL=sqlite:///data/trading.db
# For production: postgresql://user:pass@localhost:5432/cryptotrade

# Redis (for caching and real-time data)
REDIS_URL=redis://localhost:6379/0

# Risk Management
MAX_RISK_PER_TRADE=2.0  # Maximum 2% risk per trade
MAX_DAILY_LOSS=5.0      # Maximum 5% daily loss
MAX_PORTFOLIO_RISK=10.0 # Maximum 10% portfolio risk
MAX_OPEN_POSITIONS=10   # Maximum concurrent positions
DEFAULT_STOP_LOSS=3.0   # Default stop loss percentage
DEFAULT_TAKE_PROFIT=6.0 # Default take profit percentage

# AI Configuration
AI_PREDICTION_THRESHOLD=0.65  # Minimum confidence for AI signals
ML_MODEL_PATH=models/trading_model.pkl
ENABLE_DEEP_LEARNING=true
ENABLE_ENSEMBLE_MODELS=true

# Portfolio Management
REBALANCE_INTERVAL=24  # Hours between rebalancing
MIN_ORDER_SIZE=10      # Minimum order size in USD
MAX_ORDER_SIZE=10000   # Maximum order size in USD

# Monitoring
HEALTH_CHECK_INTERVAL=60  # Seconds
PERFORMANCE_REPORT_HOUR=0  # UTC hour for daily reports

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=your-secret-key-change-this-in-production
